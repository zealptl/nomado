{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["types/**/*", "middleware/**/*", "controllers/**/*", "routes/**/*", "lib/**/*", "server.ts", "vercel-adapter.ts"],
  "exclude": ["node_modules", "dist"]
}
